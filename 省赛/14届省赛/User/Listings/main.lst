 281          void Timer0_Init()    //1毫秒@12.000MHz
 282          {
 283   1        AUXR &= 0x7F;     //定时器时钟12T模式
 284   1        TMOD &= 0xF0;     //设置定时器模式
 285   1        TMOD |= 0x05;
 286   1        TL0 = 0;        //设置定时初始值
 287   1        TH0 = 0;        //设置定时初始值
