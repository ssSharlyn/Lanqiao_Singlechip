   3          unsigned char seg_dula[] = {0xC0,0xF9,0xA4,0xB0,0x99,0x92,0x82,0xF8,0x80,0x90,0xFF,0xBF,0xC6,0x89,0x8E,0x8
             -C,0x86,0x88}; // 数码管段码数组
   4          
   5          /**
   6           * @brief 数码管扫描函数
   7           * @param wela 位选坐标 
   8           * @param dula 段选索引
   9           * @param 小数点控制位 point 1-显示 0-隐藏
  10           */
  11          void seg_disp(unsigned char wela, unsigned char dula, bit point) {
  12   1        unsigned char temp;
  13   1        
  14   1        // --- 消影 ---
  15   1        P0 = 0xff;
  16   1        temp = P2 & 0x1f | 0xe0;
  17   1        P2 = temp;
  18   1        temp = P2 & 0x1f;
  19   1        P2 = temp;  
  20   1        
  21   1          
  22   1        // --- 位选 --- 
  23   1        P0 = 0x01 << wela;
  24   1        temp = P2 & 0x1f | 0xc0;
  25   1        P2 = temp;
  26   1        temp = P2 & 0x1f;
  27   1        P2 = temp;  
  28   1        
  29   1        // --- 段选 ---
  30   1        P0 = seg_dula[dula];
  31   1        if(point)
  32   1          P0 &= 0x7f; // 显示小数点 
  33   1        temp = P2 & 0x1f | 0xe0;
  34   1        P2 = temp;
  35   1        temp = P2 & 0x1f;
  36   1        P2 = temp;    
  37   1      }


