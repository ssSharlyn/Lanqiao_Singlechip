 113          /**
 114           * @brief  PCF8591指定通道的AD转换结果读取函数
 115           * @param  addr 控制字节(0x01-光敏电阻, 0x03-电位器Rb2)
 116           * @return 8位转换结果(0~255)
C51 COMPILER V9.60.7.0   IIC                                                               03/19/2026 18:37:01 PAGE 3   

 117           */
 118          unsigned char ad_read(unsigned char addr)
 119          {
 120   1        unsigned char temp;
 121   1        
 122   1        // --- 写入控制字节 ---
 123   1        I2CStart();
 124   1        I2CSendByte(0x90); // 发送器件写地址
 125   1        I2CWaitAck();
 126   1        I2CSendByte(addr); // 发送控制字节，选择具体的模拟输入通道
 127   1        I2CWaitAck();
 128   1        
 129   1        // --- 读取转换数据 ---
 130   1        I2CStart();
 131   1        I2CSendByte(0x91); // 发送器件读地址
 132   1        I2CWaitAck();
 133   1        temp = I2CReceiveByte(); // 读取1字节数据(当前通道的AD值)
 134   1        I2CSendAck(1); // 发送非应答信号(NACK)，告诉从机读取结束
 135   1        I2CStop();
 136   1        
 137   1        return temp;
 138   1      }
 139          
 140          /**
 141           * @brief  PCF8591 DA转换输出函数
 142           * @param  dat 待输出的模拟量数值(0~255，对应 0~5V)
 143           */
 144          void da_write(unsigned char dat)
 145          {
 146   1        I2CStart();
 147   1        I2CSendByte(0x90); // 发送器件写地址(0x90)
 148   1        I2CWaitAck();
 149   1        I2CSendByte(0x40); // 发送控制字节(0x40表示使能DAC输出)
 150   1        I2CWaitAck();
 151   1        I2CSendByte(dat); // 发送8位数字量，转换为模拟电压输出
 152   1        I2CWaitAck();
 153   1      }


