  61          /**
  62           * @brief  DS1302写入时间函数
  63           * @param  ucRTC 指向待写入时间数组的指针(格式: [0]-时, [1]-分, [2]-秒)
  64           * @note   DS1302内部使用 BCD 码存储，写入前需将十进制转换为BCD码
  65           */
  66          void write_rtc(unsigned char *ucRTC) {
  67   1        unsigned char i;
  68   1        
  69   1        Write_Ds1302_Byte(0x8e,0x00); // 解除写保护
  70   1        Write_Ds1302_Byte(0x80,0x80); // 停止时钟
  71   1        for(i = 0; i < 3; i++) {
  72   2          Write_Ds1302_Byte(0x84 - i*2, ucRTC[i] / 10 * 16 + ucRTC[i] % 10); 
  73   2        }
  74   1        Write_Ds1302_Byte(0x8e,0x80); // 开启写保护
  75   1      }
  76          
  77          /**
  78           * @brief  DS1302读取时间函数
  79           * @param  ucRTC 指向存储时间结果数组的指针
  80           * @note   读取出的数据为BCD码，需转换为十进制以便数码管显示
  81           */
  82          void read_rtc(unsigned char *ucRTC) {
  83   1        unsigned char temp;
  84   1        unsigned char i;
  85   1        
  86   1        EA = 0; // 屏蔽中断，防止 SPI 模拟时序被中断打断导致读取错误
  87   1        for(i = 0; i < 3; i++) {
  88   2          temp = Read_Ds1302_Byte(0x85 - 2*i);
  89   2          ucRTC[i] = temp / 16 * 10 + temp % 16; 
  90   2        }
  91   1        EA = 1; // 恢复中断
  92   1      }


