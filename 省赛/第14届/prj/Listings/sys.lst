   1          #include "sys.h"
   2          
   3          /**
   4           * @brief 系统硬件初始化函数
   5           * @note  上电时强制关闭数码管、蜂鸣器与继电器等外设
   6           */ 
   7          void sys_init(void) {
   8   1        unsigned char temp;
   9   1        
  10   1        // --- 熄灭数码管显示 ---
  11   1        P0 = 0xff; // 准备数据(高电平)
  12   1        temp = P2 & 0x1f | 0xe0; // 选通锁存器Y7通道
  13   1        P2 = temp; // 打开锁存器，传送数据，熄灭数码管
  14   1        temp = P2 & 0x1f; 
  15   1        P2 = temp; // 锁定锁存器
  16   1        
  17   1        // --- 关闭继电器与蜂鸣器 ---
  18   1        P0 = 0x00; // 准备数据(低电平)
  19   1        temp = P2 & 0x1f | 0xa0; // 选通锁存器Y5通道
  20   1        P2 = temp; // 打开锁存器，传送数据，关闭蜂鸣器等外设
  21   1        temp = P2 & 0x1f; 
  22   1        P2 = temp; // 锁定锁存器
  23   1      }


