 283          /**
 284           * @brief AD/DA转换任务函数
 285           * @note  由于AD转换读取到的是上一次转换的数值，因此读取两个通道的数值时需要交换通道
 286           */
 287          void ad_da_task(void) {
 288   1        // 3s内不重复触发采集，直接返回
 289   1        if(cllct_lock_flag == 1) return; 
 290   1        
 291   1        volt_1_x100 = ad_read(0x43) * 100 / 51; // 读取光敏电阻电压值
 292   1        volt_2_x100 = ad_read(0x41) * 100 / 51; // 读取电位器电压值
 293   1        
 294   1        // 检测到状态为亮
 295   1        if(volt_1_x100 > 250) {
 296   2          lit_flag = 1; // 拉高标志位
 297   2        }
 298   1        // 检测到状态为暗
 299   1        else {
 300   2          lit_flag = 0; // 重置标志位
 301   2        }
 302   1        
C51 COMPILER V9.60.7.0   MAIN                                                              03/19/2026 22:52:55 PAGE 6   

 303   1        // 从亮状态切换到暗状态
 304   1        if(lit_flag == 0 && lit_flag_old == 1) {
 305   2          cllct_flag = 1; // 触发温湿度采集
 306   2          cllct_lock_flag = 1; // 锁定采集
 307   2          timer_3s = 0;   // 重置3s计时
 308   2          seg_mode_rcd = seg_mode; // 记录切换前的界面
 309   2          seg_mode = 3;   // 切换到温湿度界面
 310   2        }
 311   1        
 312   1        lit_flag_old = lit_flag; // 更新上次亮暗状态
 313   1      }
