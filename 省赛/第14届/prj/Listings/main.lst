 315          /**
 316           * @brief DS18B20温度转换任务函数
 317           */
 318          void temperature_task(void) {
 319   1        // 采集标志为低，直接返回
 320   1        if(cllct_flag == 0) return;
 321   1        
 322   1        // 采集标志为高，开始采集
 323   1        cllct_flag = 0; // 重置采集标志
 324   1        
 325   1        // 读取温度
 326   1        temperature = read_temperature();
 327   1        
 328   1        // 湿度数据无效
 329   1        if(freq < 200 || freq > 2000) {
 330   2          humi = 255; 
 331   2        }
 332   1        // --- 数据有效时才做记录 ---
 333   1        else {  
 334   2          cllct_num++;    // 采集次数+1
 335   2          memcpy(ucRTC_rcd, ucRTC, 2); // 记录采集时的时间
 336   2          
 337   2          // --- 温度数据处理 ---
 338   2          temperature_max = temperature > temperature_max ? temperature : temperature_max; // 计算最大温度 
 339   2          temperature_sum += temperature; // 计算温度总和
 340   2          temperature_ave_x10 = temperature_sum * 10 / cllct_num; // 计算平均温度
 341   2          
 342   2          // --- 湿度数据处理 ---
 343   2          humi = 8.0 / 180 * (freq - 200) + 10;
 344   2          humi_max = humi > humi_max ? humi : humi_max; // 计算最大湿度 
 345   2          humi_sum += humi; // 计算湿度总和
 346   2          humi_ave_x10 = humi_sum * 10 / cllct_num; // 计算平均湿度
 347   2        }
 348   1        
 349   1        // 当采集到的数据均升高时，拉高标志位
 350   1        if(cllct_num >= 2 && temperature > temperature_rcd && humi > humi_rcd && humi != 255) {
 351   2          data_flag = 1;
 352   2        }
 353   1        else {
 354   2          data_flag = 0;
 355   2        }
 356   1        
 357   1        // 更新上一次采集到的数据记录
 358   1        temperature_rcd = temperature;
 359   1        humi_rcd = humi;
 360   1      }
