 477          /**
 478           * @brief 调度器任务调度函数
 479           * @note  时间片轮询调度任务函数
 480           */
 481          void scheduler_run(void) {
 482   1        unsigned char i;
 483   1        
 484   1        for(i = 0; i < task_num; i++) {
 485   2          unsigned long int now_time = uwTick; // 获取当前系统时间
 486   2          if(now_time - scheduler_task[i].lst_ms >= scheduler_task[i].prd_ms) {
 487   3            scheduler_task[i].lst_ms = now_time; // 更新任务函数上次执行时间
 488   3            scheduler_task[i].task_func(); // 执行任务函数
