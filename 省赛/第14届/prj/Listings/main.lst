 394          /**
 395           * @brief Timer 1中断服务函数
 396           */
 397          void timer1_server(void) interrupt 3 {
 398   1        // --- 系统时钟 ---
 399   1        uwTick++;   
 400   1        
 401   1        // --- 按键 ---
 402   1        if(key_flag) {
 403   2          if(++timer_2s >= 2000) {
 404   3            timer_2s = 2000; // 将计时钳位在2000 
 405   3          }
 406   2        }
 407   1        
 408   1        // --- 数码管 ---
 409   1        seg_pos = (++seg_pos) % 8; // 数码管位置索引在 0-7 之间循环切换
 410   1        if(seg_buf[seg_pos] > 20) seg_disp(seg_pos, seg_buf[seg_pos] - '.', 1); // 显示小数点
 411   1        else seg_disp(seg_pos, seg_buf[seg_pos], 0); // 熄灭小数点
 412   1        
 413   1        // --- LED ---
 414   1        // 采集温度大于温度参数时，开始计时
 415   1        if(temperature > temperature_p) { 
 416   2          // 每计时100ms翻转LED状态
 417   2          if(++timer_100ms >= 100) {
 418   3            timer_100ms = 0;
 419   3            led_flag ^= 1;  
 420   3          }
 421   2        }
 422   1        // 采集温度小于等于温度参数时，LED熄灭
 423   1        else {
 424   2          timer_100ms = 0;
 425   2          led_flag = 0;
 426   2        }
C51 COMPILER V9.60.7.0   MAIN                                                              03/19/2026 22:52:55 PAGE 8   

 427   1        
 428   1        // --- Freq ---
 429   1        // 计时1秒，读取频率值
 430   1        if(++timer_1s >= 1000) {
 431   2          timer_1s = 0; // 重置计时
 432   2          TR0 = 0; // 停止定时器0计数
 433   2          freq = (TH0 << 8) | TL0; // 读取频率值
 434   2          TL0 = TH0 = 0; // 重置计数初值
 435   2          TR0 = 1; // 开启定时器0计数
 436   2        }
 437   1        
 438   1        // --- 温湿度采集 ---
 439   1        if(cllct_lock_flag == 1) {
 440   2          timer_3s++;
 441   2          // 3秒时间到
 442   2          if(timer_3s >= 3000) {
 443   3            cllct_lock_flag = 0; // 解除采集锁定
 444   3            timer_3s = 0;
 445   3            seg_mode = seg_mode_rcd; // 返回切换前的界面
 446   3          }
 447   2        }
 448   1      }
