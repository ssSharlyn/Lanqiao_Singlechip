 453          // *** ЕїЖШЦї *** //
 454          
 455          /* ЕїЖШЦїШЮЮёНсЙЙЬхЖЈвх */
 456          typedef struct {
 457            void (*task_func)(void);  // ШЮЮёКЏЪ§
 458            unsigned long int prd_ms; // ШЮЮёжДаажмЦк
 459            unsigned long int lst_ms; // ЩЯДЮШЮЮёКЏЪ§жДааЕФЪБМф
 460          } task_t;
 461          
 462          /* ЕїЖШЦїШЮЮёКЏЪ§СаБэЪ§зщ */
 463          idata task_t scheduler_task[] = {
 464            {key_task, 10, 0},
 465            {seg_task, 200, 0},
 466            {led_task, 1, 0},
 467            {rtc_task, 300, 0},
 468            {ad_da_task, 160, 0},
 469            {temperature_task, 300, 0},
 470          };
 471          
 472          /**
 473           * @brief ЕїЖШЦїГѕЪМЛЏКЏЪ§
 474           * @note  ЛёШЁЕїЖШЦїШЮЮёКЏЪ§Ъ§СП
 475           */
 476          void scheduler_init(void) {
 477   1        task_num = sizeof(scheduler_task) / sizeof(task_t);
 478   1      }
 479          
 480          /**
 481           * @brief ЕїЖШЦїШЮЮёЕїЖШКЏЪ§
 482           * @note  ЪБМфЦЌТжбЏЕїЖШШЮЮёКЏЪ§
 483           */
 484          void scheduler_run(void) {
 485   1        unsigned char i;
 486   1        
 487   1        for(i = 0; i < task_num; i++) {
C51 COMPILER V9.60.7.0   MAIN                                                              03/21/2026 13:07:22 PAGE 9   

 488   2          unsigned long int now_time = uwTick; // ЛёШЁЕБЧАЯЕЭГЪБМф
 489   2          if(now_time - scheduler_task[i].lst_ms >= scheduler_task[i].prd_ms) {
 490   3            scheduler_task[i].lst_ms = now_time; // ИќаТШЮЮёКЏЪ§ЩЯДЮжДааЪБМф
 491   3            scheduler_task[i].task_func(); // жДааШЮЮёКЏЪ§
 492   3          }     
 493   2        }   
 494   1      }
