 460          idata task_t scheduler_task[] = {
 461            {key_task, 10, 0},
 462            {seg_task, 200, 0},
 463            {led_task, 1, 0},
 464            {rtc_task, 200, 0},
 465            {ad_da_task, 200, 0},
 466            {temperature_task, 200, 0},
 467          };
