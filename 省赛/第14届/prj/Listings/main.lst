 363          /**
 364           * @brief Timer 0初始化函数
C51 COMPILER V9.60.7.0   MAIN                                                              03/19/2026 22:52:55 PAGE 7   

 365           * @note  初始化NE555
 366           */
 367          void timer0_init(void)    
 368          {
 369   1        AUXR &= 0x7F;     //定时器时钟12T模式
 370   1        TMOD &= 0xF0;     //设置定时器模式
 371   1        TMOD |= 0x05;     //设置定时器0为16位不自动重装载计数模式
 372   1        TL0 = 0x00;       //设置定时初始值
 373   1        TH0 = 0x00;       //设置定时初始值
 374   1        TF0 = 0;        //清除TF0标志
 375   1        TR0 = 1;        //定时器0开始计数
 376   1      }
 377          
 378          /* Timer 1 */
 379          /**
 380           * @brief Timer 1初始化函数
 381           */
 382          void timer1_init(void)    //1毫秒@12.000MHz
 383          {
 384   1        AUXR &= 0xBF;     //定时器时钟12T模式
 385   1        TMOD &= 0x0F;     //设置定时器模式
 386   1        TL1 = 0x18;       //设置定时初始值
 387   1        TH1 = 0xFC;       //设置定时初始值
 388   1        TF1 = 0;        //清除TF1标志
 389   1        TR1 = 1;        //定时器1开始计时
 390   1        ET1 = 1;        // 使能定时器1中断
 391   1        EA = 1;         // 使能全局中断
 392   1      }
