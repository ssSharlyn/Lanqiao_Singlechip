  80   1        key_old = key_val; // 更新上一次按键状态
  81   1        
  82   1        switch(key_down) {
  83   2          // --- 界面按键 --- 
  84   2          case 4:
  85   2            seg_mode = (seg_mode + 1) % 3; 
