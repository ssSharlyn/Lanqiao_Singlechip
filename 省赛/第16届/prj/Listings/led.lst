  22   2          P2 = temp; // 打开锁存器，传送数据
  23   2          temp = P2 & 0x1f; 
  24   2          P2 = temp; // 锁定锁存器
  25   2          temp_1_old = temp_1; // 更新上一次LED状态
  26   2        }
  27   1      }
