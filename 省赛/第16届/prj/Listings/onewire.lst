  55          //
  56          bit init_ds18b20(void)
  57          {
  58   1          bit initflag = 0;
  59   1          
  60   1          DQ = 1;
  61   1          Delay_OneWire(12);
  62   1          DQ = 0;
  63   1          Delay_OneWire(80);
  64   1          DQ = 1;
  65   1          Delay_OneWire(10); 
  66   1          initflag = DQ;     
  67   1          Delay_OneWire(5);
  68   1        
  69   1          return initflag;
  70   1      }
  71          
  72          /**
  73           * @brief  DS18B20温度值读取函数
  74           * @return 转换后的实际温度
  75           * @note   DS18B20 默认12位分辨率，步进为0.0625°C
  76           */
  77          float read_temperature(void) {
  78   1          unsigned char low, high; // 存储温度低 8 位和高 8 位
  79   1      
  80   1          // --- 启动温度转换 ---
  81   1          init_ds18b20(); // 初始化DS18B20
  82   1          Write_DS18B20(0xcc); // 发送 Skip ROM 命令 (0xCC)，跳过 64 位序列号匹配（单总线仅一个设备时使用）
  83   1          Write_DS18B20(0x44); // 发送 Convert T 命令 (0x44)，启动温度转换
  84   1      
  85   1          
  86   1          Delay_OneWire(200); // 等待转换完成 
  87   1      
  88   1          // --- 读取暂存寄存器 ---
  89   1          init_ds18b20(); // 读取前必须再次初始化总线，否则无法通信
  90   1          Write_DS18B20(0xcc); // 再次跳过 ROM 匹配
  91   1          Write_DS18B20(0xbe); // 发送 Read Scratchpad 命令 (0xBE)，准备读取 9 字节数据
  92   1      
  93   1          low = Read_DS18B20(); // 读取温度 LSB (低 8 位)
  94   1          high = Read_DS18B20(); // 读取温度 MSB (高 8 位)
  95   1      
  96   1          return ((high << 8) | low) * 0.0625; // 返回读取的温度值
  97   1      }


