   7          #include "onewire.h"
   8          
   9          sbit DQ = P1^4;
  10          
  11          //
  12          void Delay_OneWire(unsigned int t)  
  13          {
  14   1        unsigned char i;
  15   1        while(t--){
  16   2          for(i=0;i<12;i++);
  17   2        }
  18   1      }
  19          
  20          //
  21          void Write_DS18B20(unsigned char dat)
  22          {
  23   1        unsigned char i;
  24   1        for(i=0;i<8;i++)
  25   1        {
  26   2          DQ = 0;
  27   2          DQ = dat&0x01;
  28   2          Delay_OneWire(5);
  29   2          DQ = 1;
  30   2          dat >>= 1;
  31   2        }
  32   1        Delay_OneWire(5);
  33   1      }
  34          
  35          //
  36          unsigned char Read_DS18B20(void)
  37          {
  38   1        unsigned char i;
  39   1        unsigned char dat;
  40   1        
  41   1        for(i=0;i<8;i++)
  42   1        {
  43   2          DQ = 0;
  44   2          dat >>= 1;
  45   2          DQ = 1;
  46   2          if(DQ)
  47   2          {
  48   3            dat |= 0x80;
  49   3          }     
  50   2          Delay_OneWire(5);
  51   2        }
  52   1        return dat;
  53   1      }
