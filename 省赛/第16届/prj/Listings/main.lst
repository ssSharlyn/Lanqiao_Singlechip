 446          /**
 447           * @brief 调度器任务调度函数
 448           * @note  时间片轮询调度任务函数
 449           */
 450          void scheduler_run(void) {
 451   1        unsigned char i;
 452   1        
 453   1        for(i = 0; i < task_num; i++) {
 454   2          unsigned long int now_time = uwTick; // 获取当前系统时间
 455   2          if(now_time - scheduler_task[i].lst_ms >= scheduler_task[i].prd_ms) {
 456   3            scheduler_task[i].lst_ms = now_time; // 更新任务函数上次执行时间
 457   3            scheduler_task[i].task_func(); // 执行任务函数
 458   3          }     
 459   2        }   
 460   1      }
