 155          /**
 156           * @brief EEPROM连续读取函数
 157           * @param str 存储读取结果的缓冲区指针
 158           * @param addr 读取的起始起始地址(0x00-0xFF)
 159           * @param num 待读取的字节数量
 160           */
 161          void eeprom_read(unsigned char *str, unsigned char addr, unsigned char num)
 162          {
 163   1        I2CStart();
 164   1        I2CSendByte(0xa0); // 器件写地址
 165   1        I2CWaitAck();
 166   1        I2CSendByte(addr); // 发送目标存储单元起始地址
 167   1        I2CWaitAck();
 168   1        
 169   1        I2CStart();
 170   1        I2CSendByte(0xa1); // 器件读地址
 171   1        I2CWaitAck();
 172   1        while(num--)
 173   1        {
 174   2          *str++ = I2CReceiveByte(); // 读取当前字节并移动指针
 175   2          if(num)
 176   2            I2CSendAck(0); // 如果还有下一字节，发送ACK(0)继续读取
 177   2          else
 178   2            I2CSendAck(1); // 最后一个字节，发送NACK(1)结束总线占用
C51 COMPILER V9.60.7.0   IIC                                                               03/18/2026 21:01:43 PAGE 4   

 179   2        }
 180   1        I2CStop();
 181   1      }
