 183          /**
 184           * @brief EEPROM连续写入函数
 185           * @param str 待写入数据源的指针
 186           * @param addr 写入的起始地址
 187           * @param num 待写入的字节数量
 188           * @note  注意：AT24C02每页仅8字节，跨页写入需小心地址翻转
 189           */
 190          void eeprom_write(unsigned char *str, unsigned char addr, unsigned char num)
 191          {
 192   1        I2CStart();
 193   1        I2CSendByte(0xa0); // 器件写地址
 194   1        I2CWaitAck();
 195   1        I2CSendByte(addr); // 发送起始存储单元地址
 196   1        I2CWaitAck();
 197   1        while(num--)
 198   1        {
 199   2          I2CSendByte(*str++); // 发送当前字节数据
 200   2          I2CWaitAck();
 201   2          I2C_Delay(200); // 这里的内部小延时有助于提高部分国产芯片的稳定性
 202   2        }
 203   1        I2CStop();
 204   1        //*** EEPROM接收到Stop信号后才开始内部固化，通常需要5ms
 205   1        // 这里通过10个255的延时强行锁定CPU，确保下一次读写前固化已完成
 206   1        I2C_Delay(255);
 207   1        I2C_Delay(255);
 208   1        I2C_Delay(255);
 209   1        I2C_Delay(255);
 210   1        I2C_Delay(255);
 211   1        I2C_Delay(255);
 212   1        I2C_Delay(255);
 213   1        I2C_Delay(255);
 214   1        I2C_Delay(255);
 215   1        I2C_Delay(255);
 216   1      }


