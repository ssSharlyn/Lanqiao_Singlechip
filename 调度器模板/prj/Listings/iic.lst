  13          
  14          //*** 注：将原代码中的"_nop()"删至1个
  15          //
  16          static void I2C_Delay(unsigned char n)
  17          {
  18   1          do
  19   1          {
  20   2            _nop_();  
  21   2          }
  22   1          while(n--);       
  23   1      }
  24          
  25          //
  26          void I2CStart(void)
  27          {
  28   1          sda = 1;
  29   1          scl = 1;
  30   1        I2C_Delay(DELAY_TIME);
  31   1          sda = 0;
  32   1        I2C_Delay(DELAY_TIME);
  33   1          scl = 0;    
  34   1      }
  35          
  36          //
  37          void I2CStop(void)
  38          {
  39   1          sda = 0;
  40   1          scl = 1;
  41   1        I2C_Delay(DELAY_TIME);
  42   1          sda = 1;
  43   1        I2C_Delay(DELAY_TIME);
  44   1      }
