  47          void I2CSendByte(unsigned char byt)
  48          {
  49   1          unsigned char i;
  50   1        
  51   1          for(i=0; i<8; i++){
  52   2              scl = 0;
  53   2          I2C_Delay(DELAY_TIME);
  54   2              if(byt & 0x80){
C51 COMPILER V9.60.7.0   IIC                                                               03/18/2026 21:01:43 PAGE 2   

  55   3                  sda = 1;
  56   3              }
