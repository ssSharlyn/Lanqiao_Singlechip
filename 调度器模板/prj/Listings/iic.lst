  67   1      }
  68          
  69          //
  70          unsigned char I2CReceiveByte(void)
  71          {
  72   1        unsigned char da;
  73   1        unsigned char i;
  74   1        for(i=0;i<8;i++){   
  75   2          scl = 1;
