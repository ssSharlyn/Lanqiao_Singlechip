 246           */
 247          
 248          void timer1_server(void) interrupt 3 {
 249   1        // --- 系统时钟 ---
 250   1        uwTick++;   
 251   1        
 252   1        // --- 数码管 ---
 253   1        seg_pos = (++seg_pos) % 8; // 数码管位置索引在 0-7 之间循环切换
