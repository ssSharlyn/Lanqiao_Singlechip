 255   1        else seg_disp(seg_pos, seg_buf[seg_pos], 0); // 熄灭小数点
 256   1        
 257   1        // --- LED ---
 258   1        
 259   1        
 260   1        // --- Freq ---
 261   1        // 计时1秒，读取频率值
 262   1        if(++timer_1s >= 1000) {
 263   2          timer_1s = 0; // 重置计时
 264   2          TR0 = 0; // 停止定时器0计数
 265   2          freq = (TH0 << 8) | TL0; // 读取频率值
 266   2          TL0 = TH0 = 0; // 重置计数初值
 267   2          TR0 = 1; // 开启定时器0计数
 268   2        }
 269   1        
 270   1        // --- Uart ---
 271   1        // 串口未接收到数据时，持续计时
 272   1        if(uart_rx_flag)
 273   1          uart_tick++;
 274   1      }
