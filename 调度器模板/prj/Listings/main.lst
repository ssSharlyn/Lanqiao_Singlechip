 212          /* Timer 0 - NE555 */
 213          /**
 214           * @brief Timer 0初始化函数
 215           * @note  初始化NE555
 216           */
 217          void timer0_init(void)    
 218          {
 219   1        AUXR &= 0x7F;     //定时器时钟12T模式
 220   1        TMOD &= 0xF0;     //设置定时器模式
 221   1        TMOD |= 0x05;     //设置定时器0为16位不自动重装载计数模式
 222   1        TL0 = 0x00;       //设置定时初始值
 223   1        TH0 = 0x00;       //设置定时初始值
 224   1        TF0 = 0;        //清除TF0标志
 225   1        TR0 = 1;        //定时器0开始计数
 226   1      }
 227          
 228          /* Timer 1 */
 229          /**
 230           * @brief Timer 1初始化函数
 231           */
 232          void timer1_init(void)    //1毫秒@12.000MHz
 233          {
 234   1        AUXR &= 0xBF;     //定时器时钟12T模式
 235   1        TMOD &= 0x0F;     //设置定时器模式
 236   1        TL1 = 0x18;       //设置定时初始值
 237   1        TH1 = 0xFC;       //设置定时初始值
 238   1        TF1 = 0;        //清除TF1标志
 239   1        TR1 = 1;        //定时器1开始计时
 240   1        ET1 = 1;        // 使能定时器1中断
