 343          /**
 344           * @brief 调度器任务调度函数
 345           * @note  时间片轮询调度任务函数
 346           */
 347          void scheduler_run(void) {
 348   1        unsigned char i;
 349   1        
 350   1        for(i = 0; i < task_num; i++) {
 351   2          unsigned long int now_time = uwTick; // 获取当前系统时间
 352   2          if(now_time - scheduler_task[i].lst_ms >= scheduler_task[i].prd_ms) {
 353   3            scheduler_task[i].lst_ms = now_time; // 更新任务函数上次执行时间
 354   3            scheduler_task[i].task_func(); // 执行任务函数
 355   3          }     
 356   2        }   
 357   1      }
