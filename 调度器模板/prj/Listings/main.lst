 305          /**
 306           * @brief 调度器任务调度函数
 307           * @note  时间片轮询调度任务函数
 308           */
 309          void scheduler_run(void) {
 310   1        unsigned char i;
 311   1        
 312   1        for(i = 0; i < task_num; i++) {
 313   2          unsigned long int now_time = uwTick; // 获取当前系统时间
 314   2          if(now_time - scheduler_task[i].lst_ms >= scheduler_task[i].prd_ms) {
 315   3            scheduler_task[i].lst_ms = now_time; // 更新任务函数上次执行时间
 316   3            scheduler_task[i].task_func(); // 执行任务函数
 317   3          }     
 318   2        }   
 319   1      }
