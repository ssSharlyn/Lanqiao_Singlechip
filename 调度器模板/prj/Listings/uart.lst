   1          #include "uart.h"
   2          
   3          /**
   4           * @brief 串口1初始化函数
   5           * @note  使用定时器2作为波特率发生器，配置为12T模式
   6           */
   7          void uart1_init(void) {
   8   1        SCON = 0x50;    //8位数据,可变波特率
   9   1        AUXR |= 0x01;   //串口1选择定时器2为波特率发生器
  10   1        AUXR &= 0xFB;   //定时器时钟12T模式
  11   1        T2L = 0xE6;     //设置定时初始值
  12   1        T2H = 0xFF;     //设置定时初始值
  13   1        AUXR |= 0x10;   //定时器2开始计时
  14   1        ES = 1;         // 使能串口中断(若只需发送，可关闭此项)
  15   1        EA = 1;         // 使能全局中断
  16   1      }
  17          
  18          /**
  19           * @brief  重写标准库输出函数 putchar
  20           * @param  ch 待发送字符
  21           * @return 发送成功的字符
  22           */
  23          extern char putchar(char ch) {
  24   1        SBUF = ch;
  25   1        while(TI == 0);
  26   1        TI = 0;
  27   1        return ch;
  28   1      }


