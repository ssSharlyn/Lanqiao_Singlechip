   1          #include "key.h"
   2          
   3          /** 
   4           * @brief  键盘扫描函数
   5           * @note   使用独立按键时注释掉后三行按键代码
   6           * @note   *** 注：使用NE555时，必须注释掉所有P34赋值语句，以及第四列按键所有代码
   7           * @return 按键键码值(4-19) 无按键按下时返回0
   8           */
   9          unsigned char key_read(void) {
  10   1        unsigned char temp = 0;
  11   1      
  12   1        if(P30 == 0) return 0;
  13   1        P44 = 0; P42 = 1; P35 = 1; P34 = 1; // 选中第一列 
  14   1        if(P30 == 0) temp = 7;
  15   1        if(P31 == 0) temp = 6;
  16   1        if(P32 == 0) temp = 5;
  17   1        if(P33 == 0) temp = 4;
  18   1        P44 = 1;P42 = 1;P35 = 1;P34 = 1;
  19   1        
  20   1        if(P30 == 0) return 0;
  21   1        P44 = 1; P42 = 0; P35 = 1; P34 = 1; // 选中第二列   
  22   1        if(P30 == 0) temp = 11;
  23   1        if(P31 == 0) temp = 10;
  24   1        if(P32 == 0) temp = 9;
  25   1        if(P33 == 0) temp = 8;
  26   1        P44 = 1;P42 = 1;P35 = 1;P34 = 1;
  27   1        
  28   1        if(P30 == 0) return 0;
  29   1        P44 = 1; P42 = 1; P35 = 0; P34 = 1; // 选中第三列   
  30   1        if(P30 == 0) temp = 15;
  31   1        if(P31 == 0) temp = 14;
  32   1        if(P32 == 0) temp = 13;
  33   1        if(P33 == 0) temp = 12;
  34   1        P44 = 1;P42 = 1;P35 = 1;P34 = 1;
  35   1        
  36   1        //*** 注：使用NE555时无法使用第四列按键，直接删掉
  37   1        if(P30 == 0) return 0;
  38   1        P44 = 1; P42 = 1; P35 = 1; P34 = 0; // 选中第四列   
  39   1        if(P30 == 0) temp = 19;
  40   1        if(P31 == 0) temp = 18;
  41   1        if(P32 == 0) temp = 17;
  42   1        if(P33 == 0) temp = 16;
  43   1        P44 = 1;P42 = 1;P35 = 1;P34 = 1;
  44   1        
  45   1        P3 |= 0xef; // 恢复 P3 口高电平状态，准备下一次扫描
  46   1        
  47   1        return temp;
  48   1      }


