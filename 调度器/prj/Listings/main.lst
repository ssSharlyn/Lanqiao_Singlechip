 175   1        TMOD &= 0xF0;     //设置定时器模式
 176   1        TMOD |= 0x05;     //设置计数器模式
 177   1        TL0 = 0x00;       //设置定时初始值
C51 COMPILER V9.60.7.0   MAIN                                                              06/14/2025 12:30:10 PAGE 4   

 178   1        TH0 = 0x00;       //设置定时初始值
 179   1        TF0 = 0;        //清除TF0标志
 180   1        TR0 = 1;        //定时器0开始计时
 181   1      }
