 269          /*< 调度器任务结构体定义 >*/
 270          typedef struct
 271          {
 272            void (*task_func)(void); //任务函数
 273            unsigned long int rate_ms; //任务周期
 274            unsigned long int last_ms;  //上次执行的时间
 275          }task_t;
 276          
 277          /*< 调度器任务列表数组 >*/
 278          idata task_t scheduler_task[] = 
 279          {
 280            {key_proc, 10, 0},
 281            {led_proc, 1, 0},
 282            {seg_proc, 200, 0},
 283            {ad_da_proc, 160, 0},
 284            {get_temperature, 200, 0},
 285            {get_time, 300, 0},
 286            {get_dist, 100, 0},
 287            {uart_proc, 10, 0}
 288          };
 289          
 290          /*< 调度器初始化函数 >*/
 291          idata unsigned char task_num;
 292          
 293          void scheduler_init(void)
 294          {
 295   1        task_num = sizeof(scheduler_task) / sizeof(task_t);
 296   1      }
 297          
 298          /*< 调度器运行函数 >*/
 299          void scheduler_run(void)
 300          {
 301   1        unsigned char i;
C51 COMPILER V9.60.7.0   MAIN                                                              06/14/2025 12:30:10 PAGE 6   

 302   1        for(i = 0; i < task_num; i++)
 303   1        {
 304   2          unsigned long int now_time = uwTick; //获取当前时间
 305   2          if(now_time >= scheduler_task[i].rate_ms + scheduler_task[i].last_ms)
 306   2          {
 307   3            scheduler_task[i].last_ms = now_time; // 更新任务上次运行时间
 308   3            scheduler_task[i].task_func();        // 执行任务
 309   3          }     
 310   2        }
 311   1      }
