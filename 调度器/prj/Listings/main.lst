 183          
 184          /*** Timer 1 ***/
 185          void Timer1_Init(void)    //1毫秒@12.000MHz
 186          {
 187   1        AUXR &= 0xBF;     //定时器时钟12T模式
 188   1        TMOD &= 0x0F;     //设置定时器模式
 189   1        TL1 = 0x18;       //设置定时初始值
 190   1        TH1 = 0xFC;       //设置定时初始值
 191   1        TF1 = 0;        //清除TF1标志
 192   1        TR1 = 1;        //定时器1开始计时
 193   1        ET1 = 1;
 194   1        EA = 1;
 195   1      }
