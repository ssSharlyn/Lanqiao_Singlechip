  20          //
  21          void Write_DS18B20(unsigned char dat)
  22          {
  23   1        unsigned char i;
  24   1        for(i=0;i<8;i++)
  25   1        {
  26   2          DQ = 0;
  27   2          DQ = dat&0x01;
